{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the INTRO AI application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "resumeText": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "language": { "type": "string" },
            "responseLength": { "type": "string", "enum": ["short", "bullet", "detailed"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Interview": {
      "title": "Interview",
      "description": "An interview session.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "transcript": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "speaker": { "type": "string", "enum": ["interviewer", "assistant"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "summary": { "type": "string" },
        "language": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and settings."
    },
    "/interviews/{interviewId}": {
      "schema": { "$ref": "#/entities/Interview" },
      "description": "Saved interview sessions."
    }
  }
}
